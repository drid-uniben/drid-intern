NODE_ENV=
PORT=

# Express trust proxy setting. Use 1 for a single reverse proxy (Render/NGINX), false for direct local traffic.
TRUST_PROXY=1
RATE_LIMIT_WINDOW_MS= 
RATE_LIMIT_MAX= 
AUTH_RATE_LIMIT_MAX= 
SUBMISSION_RATE_LIMIT_MAX= 

# DB - Use postgres
DATABASE_URL=
# Only required in development for Prisma
SHADOW_DATABASE_URL=


FRONTEND_URL=
# Comma-separated list of allowed frontend origins for CORS.
# Example: http://127.0.0.1:3000,http://127.0.0.1:3001
ALLOWED_ORIGINS=
API_URL=

LOG_LEVEL=

# Generate with: openssl rand -hex 128
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=

ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=